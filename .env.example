# Server
PORT=3000

# OpenAI
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o-mini

# SMTP (for sending lead emails with chat log)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@example.com
SMTP_PASS=your_smtp_password_or_app_password

# Lead mail routing
LEAD_SENDER_EMAIL=you@example.com
LEAD_RECEIVER_EMAIL=sales@example.com
